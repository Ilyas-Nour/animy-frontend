# Environment Variables for Production

# Copy this file to .env.production for production deployment
# Or set these variables in your deployment platform (Vercel, Netlify, etc.)

# ============================================
# REQUIRED: Update these with your domain
# ============================================

# Your production domain (no trailing slash)
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Backend API URL (update with your backend domain)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ============================================
# OPTIONAL: Analytics & Tracking
# ============================================

# Google Analytics 4 Measurement ID
# Get this from: https://analytics.google.com
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console Verification
# Get this from: https://search.google.com/search-console
# NEXT_PUBLIC_GSC_VERIFICATION=your-verification-code

# ============================================
# OPTIONAL: Social Media
# ============================================

# Twitter handle (without @)
# NEXT_PUBLIC_TWITTER_HANDLE=animy

# Facebook App ID (for Open Graph)
# NEXT_PUBLIC_FACEBOOK_APP_ID=your-app-id

# ============================================
# NOTES
# ============================================

# 1. Never commit .env.production to git
# 2. Add .env.production to .gitignore
# 3. Set these in your deployment platform's environment variables
# 4. Restart your application after changing environment variables
# 5. For local production testing: npm run build && npm run start
